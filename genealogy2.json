[
  {
    "id": 1,
    "title": "會員資料",
    "note": "<div>\n        <label>文字篩選1：</label>\n        <input type=\"text\" id=\"textFilter1\" placeholder=\"輸入文字...\">\n        <label>文字篩選2：</label>\n        <input type=\"text\" id=\"textFilter2\" placeholder=\"輸入文字...\">\n        <label>地區選單：</label>\n        <select id=\"regionFilter\">\n            <option value=\"\">--全部--</option>\n        </select>\n        <button onclick=\"applyFilter()\">篩選</button>\n    </div>\n\n    <h2 id=\"filter-title\">全部資料表</h2>\n\n    <div id=\"result-table\">載入中...</div>\n\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js\"></script>\n\n    <script>\n        let allData = [];\n\n        function stripHtml(str) {\n            if (typeof str !== 'string') return str || \"\";\n            return str.replace(/<[^>]*>/g, '');\n        }\n\n        function getTodayROC() {\n            const today = new Date();\n            const rocYear = today.getFullYear() - 1911;\n            const rocMonth = today.getMonth() + 1;\n            return { rocYear, rocMonth };\n        }\n\n        function parseBirthROC(birth) {\n            if (!birth) return null;\n            const cleanBirth = stripHtml(birth);\n            const match = cleanBirth.match(/民國\\s*(\\d+)\\.(\\d+)\\./);\n            if (!match) return null;\n            const year = parseInt(match[1], 10);\n            const month = parseInt(match[2], 10);\n            return { year, month };\n        }\n\n        function calculateAge(birth) {\n            const birthROC = parseBirthROC(birth);\n            if (!birthROC) return \"\";\n            const { rocYear, rocMonth } = getTodayROC();\n            const diffYear = rocYear - birthROC.year;\n            const diffMonth = rocMonth - birthROC.month;\n            const age = diffYear + diffMonth / 12;\n            return age.toFixed(1);\n        }\n\n        function extractRegion(address) {\n            if (!address) return \"\";\n            const match = address.match(/(.+?)(國|縣|鎮|區)/);\n            return match ? match[0] : \"\";\n        }\n\n        function buildTable(data, filterText1, filterText2, filterRegion) {\n            let maleCount = data.filter(i => stripHtml(i.gender) === \"男\").length;\n            let femaleCount = data.filter(i => stripHtml(i.gender) === \"女\").length;\n            const total = data.length;\n            const allCount = allData.length;\n\n            let title = \"全部資料表\";\n            let conditions = [];\n            if (filterText1) conditions.push(`\"${filterText1}\"`);\n            if (filterText2) conditions.push(`\"${filterText2}\"`);\n            if (filterRegion) conditions.push(`\"${filterRegion}\"`);\n            if (conditions.length > 0) {\n                title = conditions.join(\" 或 \") + \" 資料篩選結果\";\n            }\n            document.getElementById(\"filter-title\").innerText = title;\n\n            let html = \"<table>\";\n            html += `<tr class=\"stats-row\"><th colspan=\"10\">\n        <span class=\"male-stats\">男性：${maleCount} 人</span>　\n        <span class=\"female-stats\">女性：${femaleCount} 人</span>　\n        <span class=\"total-stats\">符合條件：${total} 筆</span>　\n        <span class=\"all-stats\">總共有：${allCount} 筆</span>&emsp;&emsp;\n        <button id=\"downloadExcel\" onclick=\"exportExcel()\">下載 Excel</button>\n      </th></tr>`;\n            html += \"<tr><th>編號</th><th>姓名</th><th>性別</th><th>出生年月日</th><th>年紀 / 歲</th><th>出生地</th><th>住址</th><th>備註</th><th>變動前編號</th></tr>\";\n            \n            data.forEach(item => {\n                const age = calculateAge(item.birth);\n                html += `<tr>\n          <td>${item.id || \"\"}</td>\n          <td>${item.name || \"\"}</td>\n          <td>${item.gender || \"\"}</td>\n          <td>${item.birth || \"\"}</td>\n          <td>${age}</td>\n          <td>${item.birthplace || \"\"}</td>\n          <td>${item.address || \"\"}</td>\n          <td>${item.note || \"\"}</td>\n          <td>${item.prev_id || \"\"}</td>\n        </tr>`;\n            });\n            html += \"</table>\";\n            document.getElementById(\"result-table\").innerHTML = html;\n        }\n\n        function exportExcel() {\n            if (typeof XLSX === 'undefined') {\n                alert('Excel 套件尚未加載完畢，請稍候再試');\n                return;\n            }\n            var originalTable = document.querySelector(\"table\");\n            if (!originalTable) return alert(\"找不到表格資料\");\n\n            var clonedTable = originalTable.cloneNode(true);\n            var cells = clonedTable.getElementsByTagName(\"td\");\n            for (var i = 0; i < cells.length; i++) {\n                cells[i].textContent = stripHtml(cells[i].innerHTML);\n            }\n\n            var wb = XLSX.utils.table_to_book(clonedTable, { sheet: \"篩選結果\" });\n            XLSX.writeFile(wb, \"篩選結果.xlsx\");\n        }\n\n        function applyFilter() {\n            const textValue1 = document.getElementById(\"textFilter1\").value.trim();\n            const textValue2 = document.getElementById(\"textFilter2\").value.trim();\n            const regionValue = document.getElementById(\"regionFilter\").value;\n            \n            const filtered = allData.filter(item => {\n                const cleanName = stripHtml(item.name);\n                const cleanAddress = stripHtml(item.address);\n                const cleanBirthplace = stripHtml(item.birthplace);\n\n                const matchText1 = textValue1 ? (\n                    cleanName.includes(textValue1) ||\n                    cleanAddress.includes(textValue1) ||\n                    cleanBirthplace.includes(textValue1)\n                ) : false;\n                \n                const matchText2 = textValue2 ? (\n                    cleanName.includes(textValue2) ||\n                    cleanAddress.includes(textValue2) ||\n                    cleanBirthplace.includes(textValue2)\n                ) : false;\n                \n                const matchRegion = regionValue ? cleanAddress.includes(regionValue) : false;\n                return matchText1 || matchText2 || matchRegion;\n            });\n            buildTable(filtered, textValue1, textValue2, regionValue);\n        }\n\n        window.exportExcel = exportExcel;\n        window.applyFilter = applyFilter;\n\n        fetch('data2.json')\n            .then(res => res.json())\n            .then(data => {\n                allData = data;\n                buildTable(allData, \"\", \"\", \"\");\n\n                const regions = new Set();\n                data.forEach(item => {\n                    if (item && item.address) {\n                        const cleanAddress = stripHtml(item.address);\n                        const region = extractRegion(cleanAddress);\n                        if (region) regions.add(region);\n                    }\n                });\n                const select = document.getElementById(\"regionFilter\");\n                regions.forEach(r => {\n                    const opt = document.createElement(\"option\");\n                    opt.value = r;\n                    opt.textContent = r;\n                    select.appendChild(opt);\n                });\n            })\n            .catch(err => {\n                document.getElementById(\"result-table\").innerHTML = \"載入失敗：\" + err.message;\n            });\n    </script>"
  }
]