    "title": "會員資料2僅提供給scholarship2.html",
    "note": "    <div>\n        <label>文字篩選1：</label>\n        <input type=\"text\" id=\"textFilter1\" placeholder=\"輸入文字...\">\n        <label>文字篩選2：</label>\n        <input type=\"text\" id=\"textFilter2\" placeholder=\"輸入文字...\">\n        <label>地區選單：</label>\n        <select id=\"regionFilter\">\n            <option value=\"\">--全部--</option>\n        </select>\n        <button onclick=\"applyFilter()\">篩選</button>\n    </div>\n\n    <h2 id=\"filter-title\">全部資料表</h2>\n\n    <div id=\"result-table\">載入中...</div>\n\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js\"></script>\n\n    <script>\n        let allData = [];\n        /*\n                // 🌟 新增：萬用去 HTML 標籤輔助函式\n                function stripHtml(str) {\n                    if (typeof str !== 'string') return str || \"\";\n                    return str.replace(/<[^>]*>/g, '');\n                }\n        */\n\n        function stripHtml(str) {\n            // 異動點：新增型態判斷。如果不是字串（例如純數字的 ID），就強制轉成字串，避免 .replace() 噴錯\n            if (typeof str !== 'string') return str !== undefined && str !== null ? String(str) : \"\";\n            return str.replace(/<[^>]*>/g, '');\n        }\n\n        function getTodayROC() {\n            const today = new Date();\n            const rocYear = today.getFullYear() - 1911;\n            const rocMonth = today.getMonth() + 1;\n            return { rocYear, rocMonth };\n        }\n\n        function parseBirthROC(birth) {\n            if (!birth) return null;\n            // 🌟 修改：先將生日可能含有的 HTML 標籤去掉，以符合正規表示式\n            const cleanBirth = stripHtml(birth);\n            const match = cleanBirth.match(/民國\\s*(\\d+)\\.(\\d+)\\./);\n            if (!match) return null;\n            const year = parseInt(match[1], 10);\n            const month = parseInt(match[2], 10);\n            return { year, month };\n        }\n\n        function calculateAge(birth) {\n            const birthROC = parseBirthROC(birth);\n            if (!birthROC) return \"\";\n            const { rocYear, rocMonth } = getTodayROC();\n            const diffYear = rocYear - birthROC.year;\n            const diffMonth = rocMonth - birthROC.month;\n            const age = diffYear + diffMonth / 12;\n            return age.toFixed(1);\n        }\n\n        function extractRegion(address) {\n            if (!address) return \"\";\n            const match = address.match(/(.+?)(國|縣|鎮|區)/);\n            return match ? match[0] : \"\";\n        }\n\n        function buildTable(data, filterText1, filterText2, filterRegion) {\n            // 🌟 修改：統計男女人數時先去標籤，避免 gender 欄位內的 HTML 語法干擾\n            let maleCount = data.filter(i => stripHtml(i.gender) === \"男\").length;\n            let femaleCount = data.filter(i => stripHtml(i.gender) === \"女\").length;\n            const total = data.length;\n            const allCount = allData.length;\n\n            // 更新標題\n            let title = \"全部資料表\";\n            let conditions = [];\n            if (filterText1) conditions.push(`\"${filterText1}\"`);\n            if (filterText2) conditions.push(`\"${filterText2}\"`);\n            if (filterRegion) conditions.push(`\"${filterRegion}\"`);\n            if (conditions.length > 0) {\n                title = conditions.join(\" 或 \") + \" 資料篩選結果\";\n            }\n            document.getElementById(\"filter-title\").innerText = title;\n\n            let html = \"<table>\";\n            html += `<tr class=\"stats-row\"><th colspan=\"10\">\n        <span class=\"male-stats\">男性：${maleCount} 人</span>　\n        <span class=\"female-stats\">女性：${femaleCount} 人</span>　\n        <span class=\"total-stats\">符合條件：${total} 筆</span>　\n        <span class=\"all-stats\">總共有：${allCount} 筆</span>&emsp;&emsp;\n        <button id=\"downloadExcel\" onclick=\"exportExcel()\">下載 Excel</button>\n      </th></tr>`;\n            html += \"<tr><th>編號</th><th>姓名</th><th>性別</th><th>出生年月日</th><th>年紀 / 歲</th><th>出生地</th><th>住址</th><th>備註</th><th>變動前編號</th></tr>\";\n\n            // 畫面渲染依然輸出含原汁原味 HTML 語法的 JSON 值\n            data.forEach(item => {\n                const age = calculateAge(item.birth);\n                html += `<tr>\n          <td>${item.id || \"\"}</td>\n          <td>${item.name || \"\"}</td>\n          <td>${item.gender || \"\"}</td>\n          <td>${item.birth || \"\"}</td>\n          <td>${age}</td>\n          <td>${item.birthplace || \"\"}</td>\n          <td>${item.address || \"\"}</td>\n          <td>${item.note || \"\"}</td>\n          <td>${item.prev_id || \"\"}</td>\n        </tr>`;\n            });\n            html += \"</table>\";\n            document.getElementById(\"result-table\").innerHTML = html;\n        }\n\n        // 匯出 EXCEL 檔案\n        function exportExcel() {\n            // 取得當前畫面上的表格\n            var originalTable = document.querySelector(\"table\");\n            if (!originalTable) return alert(\"找不到表格資料\");\n\n            // 🌟 修改：複製一份表格節點，動態將裡面所有的 <td> 標籤內容去除 HTML 碼，確保匯出的 Excel 是乾淨純文字\n            var clonedTable = originalTable.cloneNode(true);\n            var cells = clonedTable.getElementsByTagName(\"td\");\n            for (var i = 0; i < cells.length; i++) {\n                cells[i].textContent = stripHtml(cells[i].innerHTML);\n            }\n\n            // 將處理過（沒有網頁標籤）的 HTML Table 轉成 SheetJS 的工作表\n            var wb = XLSX.utils.table_to_book(clonedTable, { sheet: \"篩選結果\" });\n\n            // 下載 Excel 檔案\n            XLSX.writeFile(wb, \"篩選結果.xlsx\");\n        }\n\n        function applyFilter() {\n            const textValue1 = document.getElementById(\"textFilter1\").value.trim();\n            const textValue2 = document.getElementById(\"textFilter2\").value.trim();\n            const regionValue = document.getElementById(\"regionFilter\").value;\n\n            //修改：比對前先把欄位值用 stripHtml 轉回乾淨的純文字 \n            //異動點：獨立出一個萬用檢查函式，打包所有欄位\n            const checkMatch = (item, searchValue) => {\n                if (!searchValue) return false;\n\n                // 將所有原始 JSON 欄位都轉換並去除 HTML 標籤\n                const cleanId = stripHtml(item.id);\n                const cleanName = stripHtml(item.name);\n                const cleanGender = stripHtml(item.gender);\n                const cleanBirth = stripHtml(item.birth);\n                const cleanBirthplace = stripHtml(item.birthplace);\n                const cleanAddress = stripHtml(item.address);\n                const cleanNote = stripHtml(item.note);\n                const cleanPrevId = stripHtml(item.prev_id);\n\n                // 核心異動：因為原始資料沒年齡欄位，在此即時計算出「年紀」純文字以供搜尋\n                const cleanAge = calculateAge(item.birth);\n\n                // 檢查輸入的關鍵字是否包含在任一欄位中\n                return (\n                    cleanId.includes(searchValue) ||\n                    cleanName.includes(searchValue) ||\n                    cleanGender.includes(searchValue) ||\n                    cleanBirth.includes(searchValue) ||\n                    cleanAge.includes(searchValue) || // 年紀比對\n                    cleanBirthplace.includes(searchValue) ||\n                    cleanAddress.includes(searchValue) ||\n                    cleanNote.includes(searchValue) ||\n                    cleanPrevId.includes(searchValue)\n                );\n            };\n\n            const filtered = allData.filter(item => {\n                // 如果完全沒輸入任何條件，直接回傳 true 顯示全部\n                if (!textValue1 && !textValue2 && !regionValue) return true;\n\n                const matchText1 = textValue1 ? checkMatch(item, textValue1) : false;\n                const matchText2 = textValue2 ? checkMatch(item, textValue2) : false;\n\n                const cleanAddress = stripHtml(item.address);\n                const matchRegion = regionValue ? cleanAddress.includes(regionValue) : false;\n\n                return matchText1 || matchText2 || matchRegion;\n            });\n\n            buildTable(filtered, textValue1, textValue2, regionValue);\n        }\n\n        fetch('data2.json')\n            .then(res => res.json())\n            .then(data => {\n                allData = data; // 🌟 核心：全域變數依然維持原始含有 HTML 標籤的 JSON 資料\n                buildTable(allData, \"\", \"\", \"\");\n\n                // 建立下拉選單\n                const regions = new Set();\n                data.forEach(item => {\n                    // 🌟 修改：地址先動態去除 HTML 標籤後，再擷取地區字串，避免選單破版\n                    const cleanAddress = stripHtml(item.address);\n                    const region = extractRegion(cleanAddress);\n                    if (region) regions.add(region);\n                });\n                const select = document.getElementById(\"regionFilter\");\n                regions.forEach(r => {\n                    const opt = document.createElement(\"option\");\n                    opt.value = r;\n                    opt.textContent = r; // 選單文字呈現乾淨純文字\n                    select.appendChild(opt);\n                });\n            })\n            .catch(err => {\n                document.getElementById(\"result-table\").innerHTML = \"載入失敗：\" + err.message;\n            });\n    </script>"
  }
]